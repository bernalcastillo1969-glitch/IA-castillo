{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/chat", "dest": "/api/index.py" },
    { "src": "/history", "dest": "/api/index.py" },
    { "src": "/google-login", "dest": "/api/index.py" },
    { "src": "/verify", "dest": "/api/index.py" },
    { "src": "/register", "dest": "/api/index.py" },
    { "src": "/stats", "dest": "/api/index.py" },
    { "src": "/tts", "dest": "/api/index.py" },
    { "src": "/admin/castillo/stats", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/static/(.*)", "dest": "/api/static/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
